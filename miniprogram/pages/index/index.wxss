.container {
  width: 100%;
  height: 100vh;
  background: linear-gradient(180deg, #FFE5E5 0%, #FFF5F5 100%);
  display: flex;
  flex-direction: column;
  overflow-x: hidden;
}

/* 顶部栏 */
.header {
  width: 500rpx;
  margin: 0 auto;
  padding: 20rpx 0 30rpx;
  text-align: center;
  background: #FFF;
  border-radius: 0 0 40rpx 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 182, 193, 0.2);
}

.couple-info {
  position: relative;
  width: 200rpx;
  height: 100rpx;
  margin: 0 auto 20rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid #FFB6C1;
  position: absolute;
}

.avatar-left {
  left: 0;
  z-index: 2;
}

.avatar-right {
  right: 0;
  z-index: 1;
}

.couple-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF69B4;
  display: block;
  margin-bottom: 10rpx;
}

.love-days {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
}

.emoji {
  font-size: 32rpx;
  margin: 0 10rpx;
}

.days-text {
  color: #333;
  font-weight: 500;
}

/* 时光轴滚动区 */
.timeline-scroll {
  flex: 1;
  padding: 20rpx 30rpx 120rpx;
}

/* 日期卡片 */
.date-card {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 20rpx 0;
}

.date-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.date-text {
  font-size: 26rpx;
  color: #999;
}

/* 日常卡片 */
.daily-card {
  background: #FFF;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 卡片头部 */
.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.author-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 2rpx solid #FFE5E5;
}

.header-info {
  flex: 1;
}

.publish-time {
  font-size: 24rpx;
  color: #999;
}

/* 文字内容 */
.card-content {
  font-size: 28rpx;
  line-height: 1.5;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

/* 图片网格 */
.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.image-grid.single {
  grid-template-columns: 1fr;
}

.grid-image {
  width: 100%;
  height: 200rpx;
  border-radius: 12rpx;
}

.image-grid.single .grid-image {
  height: 400rpx;
}

/* 视频封面 */
.video-cover {
  position: relative;
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.play-icon {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 100rpx;
  height: 100rpx;
}

/* 卡片底部 */
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  font-size: 24rpx;
  color: #FF69B4;
  background: #FFE5E5;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.location {
  font-size: 24rpx;
  color: #666;
}

/* 加载状态 */
.loading-more,
.no-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 24rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 200rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 底部TabBar */
.bottom-tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #FFF;
  border-top: 1rpx solid #F0F0F0;
  padding: 20rpx 0;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
}

.tab-icon {
  display: block;
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.tab-item.active .tab-icon {
  color: #FF69B4;
}

.tab-text {
  font-size: 22rpx;
  color: #666;
}

.tab-item.active .tab-text {
  color: #FF69B4;
  font-weight: 600;
}
.card-action-sheet-float{
  position: absolute;
    width: 50px;
    background-color: #fff;
    right: 0;
}
.card-action-sheet-float-inner{
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10px 0;
}
<view class="profile-container">
    <scroll-view class="content-scroll" scroll-y>
        <!-- 用户信息卡片（无绑定） -->
        <view class="user-card">
            <view class="user-avatars">
                <view class="avatar-item" open-type="chooseAvatar">
                    <view class="couple-info">
                        <image class="avatar avatar-left" src="https://636c-cloud1-5g9hjld9cb8fe986-1310518816.tcb.qcloud.la/image/avatar.png?sign=a1d2f2c76c847588d578eda29decd4e1&t=1771920256" mode="aspectFill"></image>
                        <image class="avatar avatar-right" src="https://636c-cloud1-5g9hjld9cb8fe986-1310518816.tcb.qcloud.la/image/couple.png?sign=7969f2a69762c05e8992f6f7d0baa8c2&t=1771920305" mode="aspectFill"></image>
                    </view>
                </view>
            </view>
            <view class="love-info">
                <text class="love-date">{{loveStartDate}}</text>
            </view>
        </view>
        <view class="section">
            <view class="menu-list">
                <view class="menu-item" bindtap="aboutUs">
                    <view class="menu-left">
                        <text class="menu-icon">💝</text>
                        <text class="menu-text">关于我们</text>
                    </view>
                    <view class="menu-right">
                        <text class="menu-arrow">›</text>
                    </view>
                </view>

                <view class="menu-item" bindtap="feedback">
                    <view class="menu-left">
                        <text class="menu-icon">💌</text>
                        <text class="menu-text">意见反馈</text>
                    </view>
                    <view class="menu-right">
                        <text class="menu-arrow">›</text>
                    </view>
                </view>

                <view class="menu-item" bindtap="share">
                    <view class="menu-left">
                        <text class="menu-icon">📤</text>
                        <text class="menu-text">分享给好友</text>
                    </view>
                    <view class="menu-right">
                        <text class="menu-arrow">›</text>
                    </view>
                </view>
            </view>
        </view>

    </scroll-view>
</view>
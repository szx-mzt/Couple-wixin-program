.profile-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #ffe6f0 0%, #f5f5f5 30%);
}

.content-scroll {
  height: 100vh - 30rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}

/* 情侣信息卡片 */
.couple-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 50rpx 30rpx;
  margin: 30rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(255, 105, 180, 0.15);
}

.couple-avatars {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.avatar-item {
  margin-top: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.avatar-wrapper {
  border: none;
  padding: 0 10rpx;
  background: none;
  width: auto !important;
}
.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  border: 4rpx solid #ff69b4;
}

.nickname {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #666;
}

.love-icon {
  font-size: 50rpx;
  margin: 0 40rpx;
}

.love-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 30rpx 0;
}

.love-days {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff69b4;
  margin-bottom: 10rpx;
}

.love-date {
  font-size: 26rpx;
  color: #999;
}

.bind-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #ff69b4, #ff1493);
  color: #fff;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  border: none;
  margin-top: 20rpx;
}

.bind-btn::after {
  border: none;
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 10rpx;
}

.unbind-btn {
  width: 100%;
  height: 68rpx;
  background-color: #fff;
  color: #999;
  border: 2rpx solid #e0e0e0;
  border-radius: 34rpx;
  font-size: 28rpx;
  margin-top: 20rpx;
}

.unbind-btn::after {
  border: none;
}

/* 功能区块 */
.section {
  margin-bottom: 30rpx;
}

.section-title {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.title-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.title-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.menu-list {
  background-color: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #333;
}

.menu-right {
  display: flex;
  align-items: center;
}

.menu-value {
  font-size: 28rpx;
  color: #999;
  margin-right: 10rpx;
}

.menu-arrow {
  font-size: 40rpx;
  color: #ccc;
  font-weight: 300;
}

.color-preview {
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  margin-right: 10rpx;
  border: 2rpx solid #f0f0f0;
}

.bottom-placeholder {
  height: 40rpx;
}

/* 绑定弹窗 */
.bind-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  width: 600rpx;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 15rpx;
}

.modal-desc {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  margin-bottom: 40rpx;
}

.bind-options {
  margin-bottom: 30rpx;
}

.bind-option {
  width: 100%;
  height: 100rpx;
  background-color: #fff;
  border: 2rpx solid #ff69b4;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ff69b4;
  font-size: 30rpx;
  margin-bottom: 20rpx;
}

.bind-option::after {
  border: none;
}

.option-icon {
  font-size: 40rpx;
  margin-right: 15rpx;
}

.modal-cancel {
  width: 100%;
  height: 80rpx;
  background-color: #f5f5f5;
  color: #666;
  border-radius: 20rpx;
  font-size: 30rpx;
  border: none;
}

.modal-cancel::after {
  border: none;
}

.modal-close {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #ff69b4, #ff1493);
  color: #fff;
  border-radius: 20rpx;
  font-size: 30rpx;
  border: none;
}

.modal-close::after {
  border: none;
}

.switch-wrapper {
  display: flex;
  align-items: center;
}

.switch-wrapper switch {
  transform: scale(0.8);
  transform-origin: right center;
}
.couple-info {
    position: relative;
    width: 230rpx;
    height: 100rpx;
    margin: 0 auto 20rpx;
  }

  .avatar {
    width: 120rpx;
    height: 120rpx;
    border-radius: 50%;
    border: 4rpx solid #FFB6C1;
    position: absolute;
  }
  
  .avatar-left {
    left: 0;
    z-index: 2;
  }
  
  .avatar-right {
    right: 0;
    z-index: 1;
  }
/* pages/settings/settings.wxss */
.settings-page {
  height: 100vh;
  box-sizing: border-box;
}

.section {
  margin: 24rpx 24rpx 0;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.color-preview-dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.color-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.color-item {
  width: 132rpx;
  height: 80rpx;
  border-radius: 14rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: transform 0.15s;
}

.color-item.selected {
  box-shadow: 0 0 0 4rpx rgba(0, 0, 0, 0.25);
  transform: scale(1.06);
}

.check-icon {
  font-size: 28rpx;
  font-weight: bold;
  line-height: 1;
  margin-bottom: 4rpx;
}

.color-name {
  font-size: 20rpx;
  line-height: 1;
}

/* 效果预览 */
.preview-card {
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.preview-nav {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-nav-title {
  font-size: 30rpx;
  font-weight: 600;
}

.preview-content {
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 14rpx;
  flex-wrap: wrap;
}

.preview-tag {
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
}

.preview-text {
  font-size: 26rpx;
  color: #555;
  margin-top: 4rpx;
  width: 100%;
}

/* 按钮 */
.btn-group {
  margin: 32rpx 24rpx 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-save {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.15);
  border: none;
  padding: 0;
}

.btn-reset {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  color: #999;
  background: #f5f5f5;
  border: none;
}

.btn-reset::after {
  border: none;
}

.btn-save::after {
  border: none;
}

.bottom-safe {
  height: 60rpx;
}
